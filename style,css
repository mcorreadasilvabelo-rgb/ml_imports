body{
font-family:Arial;
margin:0;
background:#111;
color:white;
}

header{
text-align:center;
padding:30px;
background:black;
}

.logo{
width:120px;
}

nav{
background:#222;
text-align:center;
padding:15px;
}

nav a{
color:white;
margin:15px;
